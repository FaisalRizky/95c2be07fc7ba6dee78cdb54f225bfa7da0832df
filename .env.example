# Copy to .env and adjust to avoid port conflicts.
#
# BACKEND_PORT flows all the way through:
#   host port mapping  →  ${BACKEND_PORT}:${BACKEND_PORT}
#   uvicorn --port     →  sh -c "uvicorn ... --port ${BACKEND_PORT}"
#   nginx proxy_pass   →  proxy_pass http://backend:${BACKEND_PORT}/api/
#
# FRONTEND_PORT and ES_PORT only affect the host-side port mapping.
# nginx always listens on 80 inside the container; ES always on 9200.

FRONTEND_PORT=4200
BACKEND_PORT=8000
ES_PORT=9200
